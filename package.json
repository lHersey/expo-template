    "eslint-plugin-jest": "^27.2.2",
    "eslint-plugin-prettier": "^5.0.0-alpha.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "expo-module-scripts": "^3.0.11",
    "husky": "^8.0.3",
    "inquirer-directory": "^2.2.0",
    "jest": "^29.6.0",
    "jest-expo": "^49.0.0",
    "lint-staged": "^13.2.3",
